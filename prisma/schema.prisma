generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Report {
  id              Int     @id @default(autoincrement())
  Date            String
  Latitude        Float
  Longitude       Float
  Time            String?
  Location        String
  Activity        String
  Sec             Boolean @default(false)
  Description     String?
  Cars            String?
  Tactic          String?
  Address         String?
  RelReportID     Int?
  Agents          String?
  Radius          Float?  @default(0)
  RandomLatitude  Float   @default(0)
  RandomLongitude Float   @default(0)
  TotalPopulation Int     @default(0)
  NumAbducted     Int     @default(0)
  OnlyStreet      Boolean @default(false)
  StreetGeom      String?
  City            String?
  CreatedBy       String  @default("LUCE")
}

model Test_Report {
  id              Int     @id @default(autoincrement())
  Date            String
  Latitude        Float
  Longitude       Float
  Time            String?
  Location        String
  Activity        String
  Sec             Boolean @default(false)
  Description     String?
  Cars            String?
  Tactic          String?
  Address         String?
  RelReportID     Int?
  Agents          String?
  Radius          Float?  @default(0)
  RandomLatitude  Float   @default(0)
  RandomLongitude Float   @default(0)
  TotalPopulation Int     @default(0)
  NumAbducted     Int     @default(0)
  OnlyStreet      Boolean @default(false)
  StreetGeom      String?
  City            String?
  CreatedBy       String  @default("LUCE")
}

model Place_Of_Interest {
  id        Int    @id @default(autoincrement())
  Name      String
  Address   String
  Latitude  Float
  Longitude Float
}

model Flock_Camera {
  id           Int    @id @default(autoincrement())
  Latitude     Float
  Longitude    Float
  Manufacturer String
  Operator     String
}

model AuditLog {
  id          Int      @id @default(autoincrement())
  action      String
  resource    String
  resourceId  Int?
  actorId     String?
  actorEmail  String?
  batchId     String?
  source      String?
  snapshot    Json?
  reason      String?
  createdAt   DateTime @default(now())

  @@index([resource, resourceId])
  @@index([batchId])
  @@index([createdAt])
}

model Arrest {
  id                       Int     @id @default(autoincrement())
  ApprehensionDate         String
  ApprehensionTime         String?
  BirthYear                Int
  Gender                   String
  CitizenshipCountry       String
  ApprehensionSiteLandmark String
}

model Detainer {
  id                 Int    @id @default(autoincrement())
  Date               String
  BirthYear          Int
  Gender             String
  CitizenshipCountry String
  DetentionFacility  String
  FacilityCity       String
}
